{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-desktop",
  "version": "1.0.0",
  "identifier": "com.tilde.agent-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "S.I.G.H.T Agent",
        "width": 450,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "http://localhost:8080/api/updater/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1QkY5MTY4Qzc1MURCMEQKUldRTjIxSEhhSkcvWlZLSGNoSDZzZW5acXZKa280Qlp1QmtlbzZQcTN2QWJYWWpTR3RsVzFUS00K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}